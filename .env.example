# Local development settings. Copy this file to `.env` and fill in real
# values. `.env` is git-ignored — never commit it (this repo is public).
#
# This file is read automatically by `preapproval.config.load_env()` on
# startup (CLI and web app). Real environment variables you set in your shell
# or deployment platform always take precedence over anything here.
#
# In production, do not use a .env file at all — set these as real
# environment variables through your deployment platform's own secrets
# mechanism (systemd unit, container env, cloud secrets manager, etc.).

# Anthropic API key — optional. Only needed for the AI-assisted engine and
# free-form chat; the automatic (rule-based) engine works with no key at all.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Add other third-party keys here as the project grows, e.g.:
# SOME_OTHER_SERVICE_API_KEY=
